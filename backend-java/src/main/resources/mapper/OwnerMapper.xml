<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartpark.mapper.OwnerMapper">

    <resultMap id="OwnerMap" type="com.smartpark.entity.Owner">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="phone" property="phone"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.smartpark.entity.Owner" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO owner (name, phone)
        VALUES (#{name}, #{phone})
    </insert>

    <delete id="deleteById">
        DELETE FROM owner WHERE id = #{id}
    </delete>

    <update id="update" parameterType="com.smartpark.entity.Owner">
        UPDATE owner
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="OwnerMap">
        SELECT * FROM owner WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="OwnerMap">
        SELECT * FROM owner ORDER BY create_time DESC
    </select>

</mapper>
